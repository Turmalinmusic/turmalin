}

.bpm-points,
.attribute-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 0.7rem;
  margin-top: 1.3rem;
}

.bpm-points button,
.attribute-grid button {
  min-height: 4.6rem;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.06);
