const selectors = {
  list: document.querySelector("[data-lead-list]"),
  rowTemplate: document.querySelector("#lead-row-template"),
  detail: document.querySelector("[data-detail-card]"),
  emptyDetail: document.querySelector("[data-empty-detail]"),
  search: document.querySelector("[data-filter-search]"),
  project: document.querySelector("[data-filter-project]"),
  type: document.querySelector("[data-filter-type]"),
  status: document.querySelector("[data-filter-status]"),
  priority: document.querySelector("[data-filter-priority]"),
  sort: document.querySelector("[data-sort]"),
  count: document.querySelector("[data-result-count]"),
  metrics: {
    total: document.querySelector("[data-metric-total]"),
    turmalin: document.querySelector("[data-metric-turmalin]"),
    hot: document.querySelector("[data-metric-hot]"),
    followups: document.querySelector("[data-metric-followups]"),
  },
};

let leads = loadLeads();
let selectedLeadId = leads[0]?.id;

function withIds(items) {
  return items.map((lead, index) => {
    const contact = contactDirectory[lead.name] || {};
    return {
      ...contact,
      ...lead,
      email: lead.email || contact.email || "",
      phone: lead.phone || contact.phone || "",
      contactPerson: lead.contactPerson || contact.contactPerson || "",
      contactSource: lead.contactSource || contact.contactSource || "",
      contactNote: lead.contactNote || contact.contactNote || "",
      id: lead.id || `${lead.name.toLowerCase().replace(/[^a-z0-9]+/g, "-")}-${index}`,
      updated: lead.updated || new Date().toISOString(),
      notes: lead.notes || "",
      followups: lead.followups || 0,
    };
  });
}

function loadLeads() {
  const stored = localStorage.getItem(STORAGE_KEY);
  if (!stored) return withIds(seedLeads);
  try {
    return withIds(JSON.parse(stored));
  } catch {
    return withIds(seedLeads);
  }
}

function saveLeads() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(leads));
}

function priorityValue(priority) {
  return { A: 3, B: 2, C: 1 }[priority] || 0;
}

function statusTone(status) {
  if (["Warm", "Gebucht"].includes(status)) return "hot";
  if (["Angeschrieben", "Follow-up"].includes(status)) return "warm";
  return "cold";
}

function hasContactEmail(lead) {
  return Boolean((lead.email || "").trim());
}

function projectTone(project) {
  if (project === "Sun Spirit") return "sun";
  return "turmalin";
}

function currentFilters() {
  return {
    search: selectors.search.value.trim().toLowerCase(),
    project: selectors.project.value,
    type: selectors.type.value,
    status: selectors.status.value,
    priority: selectors.priority.value,
    sort: selectors.sort.value,
  };
}

function leadMatches(lead, filters) {
  const haystack = [
    lead.name,
    lead.type,
    lead.city,
    lead.project,
    lead.status,
    lead.email,
    lead.phone,
    lead.contactPerson,
    lead.contactSource,
    lead.sound,
    lead.angle,
    lead.next,
    lead.notes,
  ]
    .join(" ")
    .toLowerCase();

  return (
    (!filters.search || haystack.includes(filters.search)) &&
    (filters.project === "all" || lead.project === filters.project || (filters.project !== "Both" && lead.project === "Both")) &&
    (filters.type === "all" || lead.type === filters.type) &&
    (filters.status === "all" || lead.status === filters.status) &&
    (filters.priority === "all" || lead.priority === filters.priority)
  );
}

function sortLeads(items, sort) {
  return [...items].sort((a, b) => {
    if (sort === "fit") return b.fit - a.fit;
    if (sort === "updated") return new Date(b.updated) - new Date(a.updated);
    if (sort === "name") return a.name.localeCompare(b.name);
    return priorityValue(b.priority) - priorityValue(a.priority) || b.fit - a.fit;
  });
}

function renderList() {
  const filters = currentFilters();
  const filtered = sortLeads(leads.filter((lead) => leadMatches(lead, filters)), filters.sort);
  selectors.list.innerHTML = "";
  selectors.count.textContent = filtered.length;

  filtered.forEach((lead) => {
    const row = selectors.rowTemplate.content.firstElementChild.cloneNode(true);
    row.classList.toggle("is-selected", lead.id === selectedLeadId);
    row.querySelector("[data-open-detail]").textContent = lead.name;
    row.querySelector("[data-open-detail]").addEventListener("click", () => selectLead(lead.id));
    row.querySelector(".lead-note").textContent = lead.angle;
    row.querySelector("[data-type]").textContent = lead.type;
    row.querySelector("[data-city]").textContent = lead.city;
    row.querySelector("[data-contact]").textContent = hasContactEmail(lead)
      ? lead.email
      : "Noch recherchieren";
    const project = row.querySelector("[data-project]");
    project.textContent = lead.project;
    project.dataset.tone = projectTone(lead.project);
    row.querySelector("[data-fit]").value = lead.fit;
    const status = row.querySelector("[data-status]");
    status.textContent = lead.status;
    status.dataset.tone = statusTone(lead.status);
    row.querySelector("[data-next]").textContent = lead.next;
    selectors.list.append(row);
  });

  renderMetrics();
  renderDetail();
}

function renderMetrics() {
  selectors.metrics.total.textContent = leads.length;
  selectors.metrics.turmalin.textContent = leads.filter((lead) => lead.project === "TURMALIN" || lead.project === "Both").length;
  selectors.metrics.hot.textContent = leads.filter((lead) => lead.priority === "A").length;
  selectors.metrics.followups.textContent = leads.filter((lead) => lead.status === "Follow-up").length;
}

function selectLead(id) {
  selectedLeadId = id;
  renderList();
}

function updateLead(id, patch) {
  leads = leads.map((lead) =>
    lead.id === id ? { ...lead, ...patch, updated: new Date().toISOString() } : lead
  );
  saveLeads();
  renderList();
}

function mailBody(lead, project = lead.project === "Sun Spirit" ? "Sun Spirit" : "TURMALIN") {
  if (project === "Sun Spirit") {
    return [
      `Hallo ${lead.name} Team,`,
      "",
      "ich bin Philipp und spiele unter Sun Spirit elektronische Soundjourneys zwischen organischem Downtempo, Afro House, Psytech-Elementen und warmen, verbindenden Energieverlaeufen.",
      `Euer Kontext (${lead.sound}) wirkt fuer mich sehr passend, weil ich Sets gerne als Reise aufbaue: atmosphaerisch, tanzbar und mit viel Raum fuer Koerpergefuehl.`,
      "",
      "Falls ihr fuer ein kommendes Format einen Opening-, Daytime- oder Journey-Slot sucht, sende ich euch gerne EPK, Links und ein kurzes Set-Konzept.",
      "",
      "Liebe Gruesse",
      "Philipp / Sun Spirit",
    ].join("\n");
  }

  return [
    `Hallo ${lead.name} Team,`,
    "",
    "ich bin Philipp und moechte euch mein neues Projekt TURMALIN vorstellen.",
    "Der Sound ist deep, charakterstark und groove-getrieben: mal treibend progressiv oder bouncy, mal rau und texturiert, mal erdig und mystisch. Je nach Setting bewege ich mich von deepem Downtempo und Midtempo bis hin zu Indie Dance, Techno und Psytech.",
    "",
    `Bei euch sehe ich einen starken Fit, weil ${lead.angle.toLowerCase()}`,
    "Ich wuerde euch gerne ein passendes Set-Konzept fuer einen kommenden Clubabend, ein Open Air oder ein Festivalformat schicken.",
    "",
    "Links:",
    "Website: turmalin.music",
    "SoundCloud: https://soundcloud.com/turmalin-606371632",
    "Instagram: https://www.instagram.com/turmalin.music/",
    "",
    "Liebe Gruesse",
    "Philipp / TURMALIN",
  ].join("\n");
}

function renderDetail() {
  const lead = leads.find((item) => item.id === selectedLeadId);
  selectors.emptyDetail.hidden = Boolean(lead);
  selectors.detail.hidden = !lead;
  if (!lead) return;

  const projectForMail = lead.project === "Sun Spirit" ? "Sun Spirit" : "TURMALIN";
  const leadEmail = (lead.email || "").trim();
  const mailto = leadEmail
    ? `mailto:${leadEmail}?subject=${encodeURIComponent(`Booking Anfrage ${projectForMail} x ${lead.name}`)}&body=${encodeURIComponent(mailBody(lead, projectForMail))}`
    : "#";
  const contactLine = leadEmail
    ? `<p><strong>E-Mail:</strong> <a href="mailto:${leadEmail}">${leadEmail}</a></p>`
    : "<p><strong>E-Mail:</strong> Noch nicht verifiziert. Bitte Kontakt recherchieren oder unten eintragen.</p>";
  const phoneLine = lead.phone
    ? `<p><strong>Telefon:</strong> <a href="tel:${lead.phone.replace(/[^+0-9]/g, "")}">${lead.phone}</a></p>`
    : "<p><strong>Telefon:</strong> Keine Telefonnummer gefunden.</p>";
  const personLine = lead.contactPerson
    ? `<p><strong>Ansprechpartner:</strong> ${lead.contactPerson}</p>`
    : "<p><strong>Ansprechpartner:</strong> Noch offen.</p>";

