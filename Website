}

.loop-video video {
  width: 100%;
  aspect-ratio: 9 / 12;
  object-fit: cover;
}

.bpm-panel {
  padding: clamp(1rem, 3vw, 2rem);
}

.bpm-readout {
  display: grid;
  gap: 0.35rem;
  margin-bottom: 1.2rem;
}

.bpm-readout span {
  color: var(--cyan);
