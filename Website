function exportCsv() {
  const columns = [
    "name",
    "type",
    "city",
    "email",
    "phone",
    "contactPerson",
    "contactSource",
    "project",
    "priority",
    "fit",
    "status",
    "sound",
    "angle",
    "next",
    "url",
    "notes",
  ];
  const csv = [
    columns.join(","),
    ...leads.map((lead) =>
      columns
        .map((column) => `"${String(lead[column] || "").replaceAll('"', '""')}"`)
        .join(",")
    ),
  ].join("\n");
  const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.href = url;
  link.download = "turmalin-booking-crm.csv";
  link.click();
  URL.revokeObjectURL(url);
}

function bindEvents() {
  [selectors.search, selectors.project, selectors.type, selectors.status, selectors.priority, selectors.sort].forEach((input) => {
    input.addEventListener("input", renderList);
  });

  document.querySelector("[data-export-csv]").addEventListener("click", exportCsv);
  document.querySelector("[data-reset-demo]").addEventListener("click", () => {
    leads = withIds(seedLeads);
    selectedLeadId = leads[0]?.id;
    saveLeads();
    renderList();
  });

  document.querySelector("[data-quick-filters]").addEventListener("click", (event) => {
    const button = event.target.closest("button");
    if (!button) return;
    const value = button.dataset.quick;
    selectors.search.value = "";
    selectors.project.value = "all";
    selectors.status.value = "all";
    selectors.priority.value = "all";
    if (value === "TURMALIN" || value === "Sun Spirit") selectors.project.value = value;
    if (value === "A") selectors.priority.value = "A";
    if (value === "Follow-up") selectors.status.value = "Follow-up";
    renderList();
  });

  document.querySelector("[data-add-lead]").addEventListener("submit", (event) => {
    event.preventDefault();
    const form = new FormData(event.currentTarget);
    const name = form.get("name").toString().trim();
    const city = form.get("city").toString().trim();
    if (!name || !city) return;
    const lead = {
      id: `${name.toLowerCase().replace(/[^a-z0-9]+/g, "-")}-${Date.now()}`,
      name,
      city,
      type: form.get("type").toString(),
      project: form.get("project").toString(),
      priority: "B",
      fit: 70,
      status: "Neu",
      email: form.get("email").toString().trim(),
      phone: form.get("phone").toString().trim(),
      contactPerson: form.get("contactPerson").toString().trim(),
      contactSource: "Manuell hinzugefuegt",
      url: form.get("url").toString().trim() || "#",
      sound: "Noch recherchieren",
      angle: "Neu erfasster Lead, Sound-Fit und Kontaktweg pruefen.",
      next: "Recherche vervollstaendigen und Pitch Angle formulieren.",
      source: "Manuell hinzugefuegt",
      notes: "",
      followups: 0,
      updated: new Date().toISOString(),
    };
    leads = [lead, ...leads];
    selectedLeadId = lead.id;
    saveLeads();
    event.currentTarget.reset();
    renderList();
  });
}

renderTemplates();
renderBenchmarks();
bindEvents();
renderList();

